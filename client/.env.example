# API URL (optional, defaults to /api with Vite proxy in dev)
VITE_API_URL=

# OAuth Configuration. Whether each provider's buttons actually show is
# controlled at runtime by the manager Settings toggles (google_auth_enabled /
# microsoft_auth_enabled in system_config); the Microsoft button additionally
# requires VITE_MICROSOFT_CLIENT_ID to be set at build time.
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_MICROSOFT_CLIENT_ID=your-microsoft-client-id
VITE_MICROSOFT_TENANT_ID=common
